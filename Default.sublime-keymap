[
    // ── Request completion (like Copilot) ──
    {
        "keys": ["ctrl+space"],
        "command": "ollama_complete",
        "context": [
            { "key": "auto_complete_visible", "operator": "equal", "operand": false }
        ]
    },

    // ── Accept full suggestion ──
    { "keys": ["tab"], "command": "ollama_accept" },

    // ── Accept word-by-word (Copilot-style) ──
    { "keys": ["ctrl+right"], "command": "ollama_accept_word" },

    // ── Accept line-by-line ──
    { "keys": ["ctrl+down"], "command": "ollama_accept_line" },

    // ── Dismiss suggestion ──
    { "keys": ["escape"], "command": "ollama_cancel" },

    // ── Quick model switcher ──
    { "keys": ["ctrl+shift+m"], "command": "ollama_select_model" }
]
